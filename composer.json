        "wintercms",
        "winter",
        "octobercms",
        "plugin",
        "vouchers",
        "gift-card",
        "gutschein",
        "mollie",
        "qr-code",
        "pdf"
    ],
    "homepage": "https://github.com/ArtCodeStudio/wn-vouchers-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "JumpLink – Art+Code Studio",
            "email": "pascal@artandcode.studio",
            "homepage": "https://artandcode.studio"
        }
    ],
    "support": {
        "issues": "https://github.com/ArtCodeStudio/wn-vouchers-plugin/issues",
        "source": "https://github.com/ArtCodeStudio/wn-vouchers-plugin"
    },
    "require": {
        "composer/installers": "~1.0",
        "mollie/mollie-api-php": "^3.13",
        "barryvdh/laravel-dompdf": "^3.1",
        "endroid/qr-code": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    }
