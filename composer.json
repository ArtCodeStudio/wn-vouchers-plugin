{
    "name": "jumplink/wn-vouchers-plugin",
    "type": "winter-plugin",
    "description": "Gift vouchers for WinterCMS: online purchase via Mollie, digital (PDF + QR) and physical vouchers, partial redemption with a balance ledger.",
    "keywords": [
        "wintercms",
        "winter",
        "octobercms",
        "plugin",
        "vouchers",
        "gift-card",
        "gutschein",
        "mollie",
        "qr-code",
        "pdf"
    ],
    "homepage": "https://github.com/ArtCodeStudio/wn-vouchers-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "JumpLink – Art+Code Studio",
            "email": "pascal@artandcode.studio",
            "homepage": "https://artandcode.studio"
        }
    ],
    "support": {
        "issues": "https://github.com/ArtCodeStudio/wn-vouchers-plugin/issues",
        "source": "https://github.com/ArtCodeStudio/wn-vouchers-plugin"
    },
    "require": {
        "composer/installers": "~1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "extra": {
        "winter": {
            "m1-runtime-deps": [
                "mollie/mollie-api-php",
                "barryvdh/laravel-dompdf",
                "endroid/qr-code"
            ]
        }
    }
}
